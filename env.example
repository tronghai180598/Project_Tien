# Vercel → Settings → Environment Variables (Production + Preview)

# --- Recommended: Google Sheet (see google-apps-script/Code.gs) ---
# After deploying the script as a Web App, paste the URL here:
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# --- Optional: Supabase instead of / in addition (advanced) ---
# If GOOGLE_SCRIPT_URL is set, it is used first. Otherwise Supabase:
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
