# Copy to Vercel: Project → Settings → Environment Variables (Production + Preview).

# If /api/submit returns 404 after deploy, ensure the project is not configured
# as a pure static export that ignores the /api folder (this repo uses Vercel Functions).

# Random long string — use for /api/export only (header x-admin-secret).
ADMIN_SECRET=replace-with-a-long-random-secret

# Supabase: Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-never-commit
