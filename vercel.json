{
  "buildCommand": "echo 'Static site'",
  "outputDirectory": ".",
  "public": true,
  "cleanUrls": false,
  "routes": [
    {
      "src": "/experiment_stroop.html",
      "dest": "/experiment_stroop.html"
    },
    {
      "src": "/tien3.html",
      "dest": "/tien3.html"
    },
    {
      "src": "/(.*\\.html)$",
      "dest": "/$1"
    },
    {
      "src": "/",
      "dest": "/tien3.html"
    }
  ]
}

